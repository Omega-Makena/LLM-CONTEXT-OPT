# contextx environment — copy to .env and fill in real values.
# .env is gitignored; NEVER commit real keys (this is a public repo).

# --- LLM provider (pick one; auto-selects anthropic > openai > ollama > mock) ---
# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI (or OpenAI-compatible: Azure / OpenRouter / vLLM / LM Studio)
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama is local and needs no key: `ollama serve && ollama pull llama3.1`

# --- Service API keys (server-side tenant/principal mapping) ---
# JSON: {"<api-key>": {"tenant_id": "...", "principals": ["..."]}}
CONTEXTX_API_KEYS=
